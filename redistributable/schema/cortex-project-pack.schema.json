{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kaidera-os:schema:cortex-project-pack:1.0",
  "title": "Kaidera OS Project Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "pack", "assets"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "kind": {
      "type": "string",
      "const": "kaidera-os.project-pack"
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "name", "version"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,63}$"
        },
        "config": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["module"],
        "properties": {
          "module": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "portals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "type", "agent", "route_prefix", "auth", "stream_contract"],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$"
          },
          "type": {
            "type": "string",
            "enum": ["thin-web"]
          },
          "agent": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$"
          },
          "route_prefix": {
            "type": "string",
            "pattern": "^/[a-z0-9][a-z0-9/_-]{0,127}$"
          },
          "auth": {
            "type": "string",
            "enum": ["kaidera-os-auth", "external"]
          },
          "stream_contract": {
            "type": "string",
            "enum": ["runstate-sse"]
          },
          "frontend_path": {
            "type": "string",
            "minLength": 1
          },
          "docker_context": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "type"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["agent_prompt", "cortex_seed", "extension", "frontend", "filevault", "config", "docs", "other"]
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "copy_to": {
          "type": "string",
          "enum": ["project-root", "kaidera-os-extensions", "operator-selected"]
        },
        "enable_extensions_env": {
          "type": "string"
        },
        "cortex_seed_glob": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
