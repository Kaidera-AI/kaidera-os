{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local-cortex.dev/schema/cortex-project-config.schema.json",
  "title": "Cortex Redistributable Project Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "agents", "model_requirements", "beat"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "preset": {
      "type": "string"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "name", "root", "team_name"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "root": {
          "type": "string",
          "minLength": 1
        },
        "team_name": {
          "type": "string",
          "minLength": 1
        },
        "profile_globs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "knowledge_globs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "label"],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "responsibilities": {
            "type": "string"
          },
          "standard": {
            "type": "boolean"
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "display_name", "harness", "pane"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$"
          },
          "role": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "responsibilities": {
            "type": "string"
          },
          "harness": {
            "type": "string",
            "enum": [
              "kaidera",
              "codex",
              "claude",
              "claude-code",
              "gemini",
              "pi",
              "manual",
              "none"
            ]
          },
          "model": {
            "type": "string"
          },
          "managed": {
            "type": "boolean"
          },
          "pane": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "color"],
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "color": {
                "type": "string",
                "enum": ["blue", "cyan", "green", "magenta", "red", "yellow", "white"]
              },
              "order": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "model_requirements": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "required", "purpose"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["llm", "embedding", "reranking", "vision", "code"]
          },
          "required": {
            "type": "boolean"
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "recommended": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "beat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["orchestrator_agent", "cadence_minutes"],
      "properties": {
        "orchestrator_agent": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,63}$"
        },
        "cadence_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "progress_provider": {
          "type": "string",
          "enum": ["release-program", "markdown-file", "none"]
        },
        "progress_file": {
          "type": "string"
        }
      }
    }
  }
}
