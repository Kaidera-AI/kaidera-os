# ============================================================================
# Cortex Agent Memory Service — Environment Configuration
# ============================================================================
# Copy to .env and fill in local-only values.
# CTO provides real keys manually for local development. Never commit keys,
# paste them into code, or route them through GitHub/Helm/ConfigMaps.
#
# 5 Model Roles (all configurable via admin UI or env vars)
# ---------------------------------------------------------
# 1. Cortex Embeddings: sentence-transformers/all-mpnet-base-v2 (768d, for Cortex search)
# 2. Reranking: cohere/rerank-4-fast (for search result quality)
# 3. Analysis: google/gemma-4-31b-it:free (for session analysis)
# 4. Entity Extraction: google/gemma-4-31b-it:free (for knowledge graph)
# 5. App Semantic Memory: text-embedding-3-small (1536d, for Milvus/app search)
#
# Models 1-4 are Cortex-internal (this stack). Model 5 is the platform app.
# Local defaults use free models via OpenRouter — zero cost for development.
# ============================================================================

# --- Cortex API ---
CORTEX_API_URL=http://localhost:8501
# Legacy shorthand used by older portable wrappers; prefer CORTEX_API_URL.
CORTEX_API=http://localhost:8501
# REN-SEC-04: generate strong per-install secrets — do NOT ship a guessable
# default. e.g.  openssl rand -hex 32
# The API fails the admin surface closed if CORTEX_ADMIN_TOKEN is unset.
CORTEX_ADMIN_TOKEN=CHANGE_ME_run_openssl_rand_hex_32
CORTEX_JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
CORTEX_CUSTOMER=local
# K8s override: from secret kaidera-cortex
CORTEX_PROJECT=kaidera-os
# Default project/program scope for CLI scripts.

# --- Container bind-mount roots (Phase C host-zero migration) ---
# Graph worker reads project repositories through this read-only mount.
HOST_PROJECTS_ROOT=${HOME}/DevVault
# CLI/local-state ingest reads Claude session state through this read-only mount.
CLAUDE_STATE_ROOT=${HOME}/.claude/projects

# --- Model API Keys ---
OPENROUTER_API_KEY=PASTE_HERE
# Required for embeddings + rerank + analysis via OpenRouter.
# Local Cortex uses OpenRouter only; keep the real value in local-cortex/.env.
ANTHROPIC_API_KEY=
# Optional: for paid analysis model (set CORTEX_ANALYSIS_PROVIDER=anthropic)

# --- Embedding (Role 1) ---
CORTEX_EMBED_MODEL=sentence-transformers/all-mpnet-base-v2
CORTEX_EMBED_DIMS=768

# --- Reranking (Role 2) ---
CORTEX_RERANK_MODEL=cohere/rerank-4-fast

# --- Analysis (Role 3) ---
CORTEX_ANALYSIS_MODEL=google/gemma-4-31b-it:free
# Empty uses the fallback chain below
CORTEX_ANALYSIS_PROVIDER=openrouter
# openrouter or anthropic
CORTEX_ANALYSIS_FALLBACK_MODELS=nvidia/nemotron-3-super-120b-a12b:free,google/gemma-4-31b-it:free,minimax/minimax-m2.5:free,openai/gpt-oss-120b:free

# --- Entity Extraction (Role 4) ---
CORTEX_V2_ENTITY_MODEL=google/gemma-4-31b-it:free
CORTEX_ENTITY_FALLBACK_MODELS=google/gemma-4-31b-it:free,minimax/minimax-m2.5:free,openai/gpt-oss-120b:free
CORTEX_ENTITY_TIMEOUT_SECONDS=30
